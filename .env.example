# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# RunPod Serverless (step 5 — image generation)
RUNPOD_API_KEY=rpa_YOUR_KEY_HERE
RUNPOD_ENDPOINT_ID=YOUR_ENDPOINT_ID_HERE
RUNPOD_REQUEST_TIMEOUT=1800
RUNPOD_POLL_INTERVAL=3
RUNPOD_MAX_RETRIES=3

# Image output root (default: output/)
IMAGE_OUTPUT_ROOT=output

# Anthropic (step 7 — metadata)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Image generation backend selector: runpod_serverless | vast_instance
IMAGE_BACKEND=runpod_serverless

# Vast.ai (only needed when IMAGE_BACKEND=vast_instance)
# Build + push:  docker build -t ghcr.io/hugoleon1199/vast-flux-worker:v1.0.1 vast_worker/
#                docker push ghcr.io/hugoleon1199/vast-flux-worker:v1.0.1
VAST_API_KEY=your_vast_api_key_here
VAST_WORKER_IMAGE=ghcr.io/hugoleon1199/vast-flux-worker:v1.0.1
VAST_WORKER_CUSTOM_IMAGE=true           # true = skip SSH/SCP; image has server baked in
VAST_MIN_VRAM_GB=24
VAST_MAX_PRICE_PER_HOUR=0.50           # total-instance cap (1-GPU sessions)
VAST_MAX_PRICE_PER_GPU_HOUR=0.20       # per-GPU cap for multi-GPU bundles
VAST_GPU_NAME=                          # optional: RTX_4090, RTX_3090, etc.
VAST_HF_TOKEN=hf_your_token_here       # HuggingFace token for FLUX.1-dev
HF_MODEL_REVISION=3de623fc3c33e44ffbe2bad470d0f45bccf2eb21  # pin to commit SHA
VAST_DISK_GB=60
VAST_NUM_GPUS_CHOICES=1,2,3            # search 1, 2, and 3-GPU offers; pick cheapest
VAST_MODEL_LOAD_WALL_SECONDS=90        # model load estimate for cost ranking
VAST_MIN_CPU_RAM_PER_GPU_GB=32         # hard filter for multi-GPU (CPU offload needs RAM)
VAST_MIN_CPU_CORES_PER_GPU=4           # hard filter for multi-GPU
WORKER_API_TOKEN=change_me_to_a_secret # shared secret between pipeline and worker

# Skip auto-rent if you already have an instance running:
# VAST_INSTANCE_HOST=ssh4.vast.ai
# VAST_INSTANCE_PORT=12345
