# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# RunPod Serverless (step 5 — image generation)
RUNPOD_API_KEY=rpa_YOUR_KEY_HERE
RUNPOD_ENDPOINT_ID=YOUR_ENDPOINT_ID_HERE
RUNPOD_REQUEST_TIMEOUT=1800
RUNPOD_POLL_INTERVAL=3
RUNPOD_MAX_RETRIES=3

# Image output root (default: output/)
IMAGE_OUTPUT_ROOT=output

# Anthropic (step 7 — metadata)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Image generation backend selector
IMAGE_BACKEND=runpod_serverless
