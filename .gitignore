# Secrets — never commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.venv/
venv/

# Pipeline outputs (large binary files)
output/*/audio.mp3
output/*/images/
output/*/final.mp4
output/*/audio_trimmed.mp3
output/*_demo*/

# Logs
*.log
pipeline.log

# Model weights — never commit
*.safetensors
*.ckpt
*.bin
*.pt
*.pth

# Audio/video assets (large binary, not versioned)
assets/sfx/
assets/icons/*.png
assets/icons/*.svg

# Test output images and archives
test_*.webp
test_*.zip
test_*/

# Tool state — not source code
.ai/
.claude/
.fresh_endpoint

# Unprocessed video folders
VIDEO/
VIDEO-1/
master_style_seeds/

# Docker
.dockerignore

# OS
.DS_Store
Thumbs.db
